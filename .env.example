# Bilibili Cookie (SESSDATA=...)
BILI_COOKIE=

# Server Port
PORT=3001

# --- 前端构建配置 ---
# 本地开发使用 /api 代理
VITE_API_BASE_URL=/api
ADMIN_TOKEN=password

# 实际部署后使用以下代理
# VITE_ADMIN_API_BASE_URL=https://实际域名/api
# VITE_API_BASE_URL=https://实际域名/api

# --- 腾讯云 COS 配置 ---
# 请填入与 GitHub Secrets 相同的值
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
COS_BUCKET=
COS_REGION=

# --- 前端图片 CDN 域名 ---
# 生产环境：CDN 加速域名，如 https://ovodm.top
# 本地开发：也可配置为 CDN 域名直接从 COS 加载图片
VITE_COS_BASE_URL=https://ovodm.top

# --- 数据库配置 (新增) ---
# 1Panel 部署时使用：
# MYSQL_CONNECTION_STRING=server=;port=;database=;user=;password=;charset=utf8mb4;
# 本地调试使用：
MYSQL_CONNECTION_STRING=server=127.0.0.1;database=danmaku_db;user=root;password=123456;charset=utf8mb4;