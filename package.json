{
  "name": "bili-danmu-replay",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsx scripts/generate-colors.ts && vite",
    "dev:server": "cd server_net && dotnet run --urls \"http://0.0.0.0:3001\"",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "generate-avatars": "cd server_net && dotnet run --project Danmu.Server.csproj -- generate-avatars",
    "generate-colors": "npx tsx scripts/generate-colors.ts",
    "build": "npx tsx scripts/generate-colors.ts && tsc && vite build",
    "preview": "vite preview",
    "start": "cd server_net && dotnet run --urls \"http://0.0.0.0:3001\" --configuration Release"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "jimp": "^1.6.0",
    "node-vibrant": "^4.0.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.4"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.13.4",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.2",
    "html2canvas": "^1.4.1",
    "pinia": "^3.0.4",
    "sass": "^1.97.3",
    "vue-router": "^5.0.1"
  }
}
